class Solution {
    public int search(int[] nums, int target) {
        if (nums == null || nums.length == 0) return -1;
        
        // 1. Find the INDEX of the minimum element (the pivot point)
        int minIdx = findMinIndex(nums);
        
        // 2. Determine which sorted subarray to search in
        int left = 0;
        int right = nums.length - 1;
        
        if (target >= nums[minIdx] && target <= nums[right]) {
            // Target is in the right sorted portion
            left = minIdx;
        } else {
            // Target is in the left sorted portion
            right = minIdx - 1;
        }
        
        // 3. Standard binary search within the chosen bounds
        while (left <= right) {
            int mid = left + (right - left) / 2; // Prevents potential integer overflow
            if (nums[mid] == target) {
                return mid;
            } else if (nums[mid] < target) {
                left = mid + 1;
            } else {
                right = mid - 1;
            }
        }
        
        return -1;    
    }
     
    // Modified to return the INDEX of the minimum element
    public int findMinIndex(int[] nums) {
        int left = 0;
        int right = nums.length - 1;
        
        while (left < right) {
            int mid = left + (right - left) / 2;
            if (nums[mid] < nums[right]) {
                right = mid;
            } else {
                left = mid + 1;
            }
        }   
        return left; // 'left' is the index of the minimum element
    }
}
